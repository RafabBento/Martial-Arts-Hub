# Copie este arquivo para /etc/martial-arts-hub/api-server.env na VPS
# (fora do repositório — nunca commitar segredos reais).
#
#   sudo mkdir -p /etc/martial-arts-hub
#   sudo nano /etc/martial-arts-hub/api-server.env
#   sudo chown martialarts:martialarts /etc/martial-arts-hub/api-server.env
#   sudo chmod 600 /etc/martial-arts-hub/api-server.env

NODE_ENV=production
PORT=8080

# Connection string do Neon (a mesma usada em artifacts/api-server/.env local).
DATABASE_URL=postgresql://usuario:senha@host.neon.tech/neondb?sslmode=require&channel_binding=require

# Gere um valor novo e aleatório (não reutilize o de dev): openssl rand -hex 32
SESSION_SECRET=

# Mude para "true" somente depois de configurar domínio + HTTPS (Let's Encrypt).
# Em HTTP puro (acesso só por IP) TEM que ficar "false", senão o login quebra.
COOKIE_SECURE=false
